{
  "name": "aiXiv",
  "version": "0.1.0",
  "description": "A personalized digest from the arXiv",
  "repository": {
    "type": "git",
    "url": "https://github.com/haykh/aiXiv.git"
  },
  "bugs": {
    "url": "https://github.com/haykh/aiXiv/issues"
  },
  "scripts": {
    "vendor:icons": "mkdir -p aiXiv/static/vendor/icons && grep -hoP 'icon\\(\\\".*\\\"\\)' -r aiXiv/templates/ | sed 's/icon(\\\"\\(.*\\)\\\")/\\1.svg/' | xargs -I {} cp node_modules/lucide-static/icons/{} aiXiv/static/vendor/icons/",
    "vendor:htmx": "mkdir -p aiXiv/static/vendor && cp node_modules/htmx.org/dist/htmx.min.js aiXiv/static/vendor/",
    "vendor:katex": "mkdir -p aiXiv/static/vendor/katex && cp -r node_modules/katex/dist/* aiXiv/static/vendor/katex/",
    "vendor": "npm run vendor:icons && npm run vendor:htmx && npm run vendor:katex",
    "css": "sass --quiet-deps --load-path=node_modules --style=compressed scss:aiXiv/static/css",
    "css:watch": "sass --quiet-deps --load-path=node_modules --style=compressed scss:aiXiv/static/css --watch",
    "start": "concurrently \"npm run css:watch\" \"fastapi dev aiXiv/main.py\""
  },
  "keywords": [
    "library",
    "ai",
    "digest",
    "arxiv",
    "arxiv-papers",
    "llm",
    "chatgpt",
    "claude",
    "codex",
    "ollama"
  ],
  "author": {
    "name": "Hayk Hakobyan",
    "email": "haykh.astro@gmail.com",
    "url": "https://haykh.github.io/tilde/"
  },
  "license": "GPL-3.0",
  "type": "commonjs",
  "devDependencies": {
    "@picocss/pico": "^2.1.1",
    "concurrently": "^10.0.3",
    "sass": "^1.101.0"
  },
  "dependencies": {
    "htmx.org": "^2.0.10",
    "katex": "^0.17.0",
    "lucide-static": "^1.22.0"
  }
}